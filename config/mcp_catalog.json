{
  "servers": {
    "github_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "developer_platform",
      "display_name": "GitHub MCP",
      "description": "Repositories, branches, commits and pull requests.",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "required_for": [
        "backend_developer",
        "frontend_developer",
        "senior_backend",
        "devops"
      ],
      "env_keys": [
        "GITHUB_TOKEN",
        "GITHUB_BOT_USERNAME",
        "GITHUB_BOT_EMAIL"
      ]
    },
    "jira_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "project_management",
      "display_name": "Jira MCP",
      "description": "Issues, epics, user stories, comments and transitions.",
      "required_for": [
        "ceo",
        "business_analyst",
        "qa"
      ],
      "env_keys": [
        "JIRA_URL",
        "JIRA_USER",
        "JIRA_API_TOKEN",
        "JIRA_PROJECT_KEY"
      ],
      "command": "python",
      "args": [
        "mcp_servers/jira/server.py"
      ]
    },
    "confluence_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "documentation",
      "display_name": "Confluence MCP",
      "description": "Publish BRDs, technical docs and markdown pages.",
      "required_for": [
        "business_analyst",
        "technical_writer",
        "software_architect"
      ],
      "env_keys": [
        "JIRA_URL",
        "CONFLUENCE_URL",
        "CONFLUENCE_SPACE_KEY",
        "JIRA_USER",
        "JIRA_API_TOKEN"
      ],
      "command": "python",
      "args": [
        "mcp_servers/confluence/server.py"
      ]
    },
    "google_drive_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "documents",
      "display_name": "Google Drive MCP",
      "description": "Create client documents, contracts and permissions.",
      "required_for": [
        "legal",
        "technical_writer",
        "ceo"
      ],
      "env_keys": [
        "GOOGLE_DRIVE_CREDENTIALS_JSON",
        "GOOGLE_DRIVE_FOLDER_ID"
      ],
      "command": "python",
      "args": [
        "mcp_servers/google_drive/server.py"
      ]
    },
    "deploy_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "deployment",
      "display_name": "Deploy MCP",
      "description": "Vercel and Railway CLI deployments.",
      "required_for": [
        "devops"
      ],
      "env_keys": [
        "VERCEL_TOKEN",
        "RAILWAY_TOKEN"
      ],
      "command": "python",
      "args": [
        "mcp_servers/deploy/server.py"
      ]
    },
    "playwright_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "qa",
      "display_name": "Playwright MCP",
      "description": "Browser smoke tests, screenshots and E2E checks.",
      "required_for": [
        "qa",
        "frontend_developer",
        "frontend_architect"
      ],
      "env_keys": [],
      "command": "python",
      "args": [
        "mcp_servers/playwright/server.py"
      ]
    },
    "security_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "security",
      "display_name": "Security MCP",
      "description": "Bandit, npm audit and OWASP ZAP API hook.",
      "required_for": [
        "security",
        "senior_backend"
      ],
      "env_keys": [
        "ZAP_API_URL"
      ],
      "command": "python",
      "args": [
        "mcp_servers/security/server.py"
      ]
    },
    "shadcn_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "ui_library",
      "display_name": "shadcn/ui MCP",
      "description": "Browse, search and install components from shadcn-compatible registries.",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "docs_url": "https://ui.shadcn.com/docs/mcp",
      "required_for": [
        "frontend_developer",
        "frontend_architect"
      ],
      "env_keys": [],
      "install_hint": "npx shadcn@latest mcp init --client vscode"
    },
    "context7_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "library_docs",
      "display_name": "Context7 MCP",
      "description": "Up-to-date documentation and examples for libraries like Once UI, Next.js, Supabase and React.",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "docs_url": "https://context7.com/docs",
      "required_for": [
        "frontend_architect",
        "frontend_developer",
        "software_architect",
        "backend_developer"
      ],
      "env_keys": [
        "CONTEXT7_API_KEY"
      ],
      "library_ids": [
        "/once-ui-system/core",
        "/vercel/next.js",
        "/facebook/react",
        "/supabase/supabase"
      ]
    },
    "filesystem_mcp": {
      "enabled": true,
      "kind": "stdio",
      "category": "developer_tools",
      "display_name": "Filesystem MCP",
