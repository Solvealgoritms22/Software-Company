# Copy this file to .env and fill only the services you use.
# Never put real secrets in .env.example.

# Local services
# PGlite socket server defaults. Keep these unless you swap back to full PostgreSQL.
KNOWLEDGE_DB_NAME=postgres
KNOWLEDGE_DB_USER=postgres
KNOWLEDGE_DB_PASSWORD=
KNOWLEDGE_DB_PORT=5432
ORCHESTRATOR_PORT=8000
DASHBOARD_PORT=3000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
# Use the same generated value for both keys in .env. Do not commit the real value.
NEXT_PUBLIC_ORCHESTRATOR_API_KEY=
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_REQUIRE_API_KEY=false
ORCHESTRATOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MCP service ports
GITHUB_MCP_PORT=8010
JIRA_MCP_PORT=8011
CONFLUENCE_MCP_PORT=8012
GOOGLE_DRIVE_MCP_PORT=8013
DEPLOY_MCP_PORT=8014
PLAYWRIGHT_MCP_PORT=8015
SECURITY_MCP_PORT=8016

# LLM providers
# Set LLM_STRICT=true if a missing provider key should fail the phase instead of producing a placeholder artifact.
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4.1-mini
LLM_STRICT=false
MAX_INPUT_TOKENS_PER_PHASE=12000
MAX_OUTPUT_TOKENS_PER_PHASE=2000
MAX_ARTIFACT_CONTEXT_TOKENS=5000
MAX_ARTIFACT_CONTEXT_CHARS=1800
ARTIFACT_MEMORY_ENABLED=true
ARTIFACT_MEMORY_CONTEXT_TOKENS=4000
ARTIFACT_MEMORY_CHUNK_CHARS=1400
ARTIFACT_MEMORY_MAX_CHUNKS_PER_ARTIFACT=10
ARTIFACT_MEMORY_MAX_CANDIDATE_CHUNKS=500
MAX_TOOL_TURNS_PER_PHASE=6
MAX_TOOL_OUTPUT_CHARS=4000
MAX_PROJECT_COST_USD=0
MCP_SESSION_IDLE_SECONDS=300
MCP_SESSION_MAX_USES=100
MCP_TOOL_CALL_TIMEOUT_SECONDS=300
WORKSPACE_ALLOWED_COMMANDS=node,npm,npx,pnpm,yarn,python,python3,pip,pytest,git,uvicorn,playwright,vercel,railway
WORKSPACE_MAX_COMMAND_OUTPUT_CHARS=6000
WORKSPACE_ALLOW_UNSAFE_COMMANDS=false

# OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
CONTEXT7_API_KEY=

# DeepSeek API, OpenAI-compatible endpoint
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Local OpenAI-compatible providers. API keys are optional for the default local endpoints.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
LMSTUDIO_API_KEY=
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
VLLM_API_KEY=
VLLM_BASE_URL=http://host.docker.internal:8000/v1

# GitHub bot account or GitHub App token.
# Simple initial setup: classic PAT from a bot account with scopes repo and workflow.
GITHUB_TOKEN=
GITHUB_BOT_USERNAME=software-factory-bot
GITHUB_BOT_EMAIL=agents@software-factory.local

# Jira Cloud Free
JIRA_URL=https://your-company.atlassian.net
JIRA_USER=founder@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SF

# Confluence Cloud. Leave CONFLUENCE_URL empty to use ${JIRA_URL}/wiki.
CONFLUENCE_URL=
CONFLUENCE_SPACE_KEY=

# Supabase. Optional for production/client projects; local knowledge DB uses PGlite.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=

# Google Drive. Prefer GOOGLE_DRIVE_CREDENTIALS_JSON for a service account JSON string.
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_FOLDER_ID=

# Deployment providers
VERCEL_TOKEN=

# Railway docs commonly call this RAILWAY_API_TOKEN. Keep both equal if you use Railway.
RAILWAY_TOKEN=
RAILWAY_API_TOKEN=

# Security tools
ZAP_API_URL=

# Founder notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
