{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevFoundry",
  "version": "1.0.0",
  "identifier": "com.devfoundry.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3005",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "DevFoundry",
        "width": 1288,
        "height": 692,
        "minWidth": 1288,
        "minHeight": 692,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/node.exe",
      "bin/devfoundry-backend.exe",
      "knowledge_base/pglite/**/*",
      ".env.production"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "Spanish",
          "English"
        ],
        "displayLanguageSelector": false,
        "startMenuFolder": "DevFoundry",
        "compression": "lzma"
      }
    }
  }
}
