# ------------------------------------------------------------
# 1. SERVICIOS LOCALES Y BASE DE DATOS
# ------------------------------------------------------------
# Nombre de la base de datos PGlite local que almacena proyectos, agentes y configuraciones.
KNOWLEDGE_DB_NAME=postgres

# Usuario administrador predeterminado para interactuar con la base de datos local.
KNOWLEDGE_DB_USER=postgres

# Contraseña de acceso a la base de datos (se deja vacía ya que PGlite es local y embebida).
KNOWLEDGE_DB_PASSWORD=

# Puerto TCP en el que escucha el servidor de sockets de la base de datos PGlite local.
KNOWLEDGE_DB_PORT=5432

# Puerto TCP asignado al backend FastAPI del orquestador.
ORCHESTRATOR_PORT=8000

# Puerto TCP donde corre el servidor de desarrollo o producción del frontend Next.js.
DASHBOARD_PORT=3005

# URL de acceso de la API del orquestador utilizada por el frontend para hacer fetch y establecer WebSockets.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000

# Clave de API pública usada en el frontend para autenticar peticiones (debe coincidir con la del backend).
NEXT_PUBLIC_ORCHESTRATOR_API_KEY=bcF-5q0wuJQr9TJA7wdolZ_IwLrNpRTyOfcLTRzJTH4

# Clave de API privada validada en el backend orquestador para autorizar peticiones entrantes.
ORCHESTRATOR_API_KEY=bcF-5q0wuJQr9TJA7wdolZ_IwLrNpRTyOfcLTRzJTH4

# Si es true, obliga al backend a denegar cualquier petición que no incluya la cabecera X-API-Key válida.
ORCHESTRATOR_REQUIRE_API_KEY=true

# Orígenes y hosts permitidos para realizar solicitudes CORS cruzadas (CORS policy) hacia el orquestador.
ORCHESTRATOR_CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://tauri.localhost,tauri://localhost

# ------------------------------------------------------------
# 2. PUERTOS ASIGNADOS A SERVIDORES MCP (Model Context Protocol)
# ------------------------------------------------------------
# Los servidores MCP ya no utilizan puertos locales TCP.
# Ahora se ejecutan dinámicamente como subprocesos aislados a través de stdio (Standard I/O),
# garantizando cero conflictos de puertos y mejor escalabilidad.


# ------------------------------------------------------------
# 3. CONFIGURACIONES DE LLM Y DEL ORQUESTADOR
# ------------------------------------------------------------
# Proveedor de modelos de lenguaje predeterminado a usar al inicializar la fábrica (ej. openai, deepseek, ollama).
DEFAULT_LLM_PROVIDER=openai

# Nombre del modelo de lenguaje de IA predeterminado asignado a las fases del flujo de trabajo.
DEFAULT_LLM_MODEL=gpt-4.1-mini

# Si es true, el orquestador fallará la fase si el proveedor activo no tiene su clave de API configurada.
LLM_STRICT=false

# Límite máximo de tokens que se enviarán al modelo de IA como entrada en cada fase de trabajo.
MAX_INPUT_TOKENS_PER_PHASE=12000

# Límite máximo de tokens que el modelo de IA puede generar como respuesta en cada fase de trabajo.
MAX_OUTPUT_TOKENS_PER_PHASE=2000

# Límite de tokens de contexto asignado a los artefactos inyectados para el análisis de los agentes.
MAX_ARTIFACT_CONTEXT_TOKENS=5000

# Límite en caracteres del texto de los artefactos que se puede cargar directamente como contexto.
MAX_ARTIFACT_CONTEXT_CHARS=1800

# Habilita el almacenamiento y recuperación en caché de fragmentos relevantes de artefactos anteriores.
ARTIFACT_MEMORY_ENABLED=true

# Límite de tokens para la recuperación de memoria contextual de artefactos.
ARTIFACT_MEMORY_CONTEXT_TOKENS=4000

# Tamaño en caracteres de cada bloque/segmento en el que se dividen los artefactos para guardarlos en memoria.
ARTIFACT_MEMORY_CHUNK_CHARS=1400

# Número máximo de segmentos de memoria que se guardarán o rastrearán por cada artefacto individual.
ARTIFACT_MEMORY_MAX_CHUNKS_PER_ARTIFACT=10

# Límite de fragmentos candidatos a evaluar simultáneamente durante una búsqueda en la memoria de artefactos.
ARTIFACT_MEMORY_MAX_CANDIDATE_CHUNKS=500

# Si es true, utiliza búsquedas vectoriales avanzadas para encontrar similitudes semánticas en la memoria.
ARTIFACT_MEMORY_EMBEDDINGS_ENABLED=false

# Número máximo de candidatos recuperados mediante similitud vectorial (embeddings).
ARTIFACT_MEMORY_VECTOR_CANDIDATES=80

# Balance para la búsqueda híbrida (0.0 a 1.0) entre búsqueda semántica (vectorial) y léxica (palabras clave).
ARTIFACT_MEMORY_HYBRID_ALPHA=0.65

# Proveedor de embeddings para generar los vectores de la memoria (ej. openai).
EMBEDDINGS_PROVIDER=openai

# Modelo matemático de embeddings usado para codificar el texto en vectores semánticos.
EMBEDDING_MODEL=text-embedding-3-small

# Cantidad de dimensiones de salida que tiene el vector generado por el modelo de embeddings.
EMBEDDING_DIMENSIONS=768

# Habilita la caché semántica para guardar respuestas anteriores de la IA y ahorrar tiempo y coste de tokens.
SEMANTIC_CACHE_ENABLED=true

# Si es true, el orquestador reutilizará respuestas similares en caché automáticamente sin confirmación.
SEMANTIC_CACHE_AUTO_REUSE=false

# Puntuación de similitud semántica mínima (0.0 a 1.0) requerida para reutilizar una respuesta en caché.
SEMANTIC_CACHE_MIN_SCORE=0.72

# Número máximo de respuestas que se pueden almacenar y evaluar simultáneamente en la caché semántica.
SEMANTIC_CACHE_MAX_ITEMS=3

# Límite de tokens asignado al contexto histórico evaluado por la caché semántica.
SEMANTIC_CACHE_CONTEXT_TOKENS=1200

# Límite de respuestas candidatas recuperadas para evaluar una coincidencia semántica en la caché.
SEMANTIC_CACHE_CANDIDATES=100

# Activa el sistema de validación de entregables basado en contratos estructurados por fase.
PHASE_CONTRACTS_ENABLED=true

# Si es true, el orquestador intentará corregir automáticamente y por sí mismo los fallos de contrato del entregable.
PHASE_CONTRACT_AUTOFIX=true

# Habilita el uso de formatos JSON estrictos en la API del LLM para estructurar las respuestas de contratos.
PHASE_CONTRACT_SCHEMA_RESPONSE_FORMAT=true

# Número máximo de ejecuciones de herramientas consecutivas que puede hacer un agente por fase (evita bucles).
MAX_TOOL_TURNS_PER_PHASE=6

# Límite de caracteres del resultado de salida de una herramienta que se inyectará como contexto al LLM.
MAX_TOOL_OUTPUT_CHARS=4000

# Presupuesto máximo de costo del proyecto expresado en dólares estadounidenses. Si es 0, no hay límite.
MAX_PROJECT_COST_USD=0

# Tiempo máximo en segundos de inactividad de una sesión de servidor MCP antes de liberarla y cerrarla.
MCP_SESSION_IDLE_SECONDS=300

# Cantidad máxima de ejecuciones/peticiones permitidas en una sesión MCP antes de forzar su reciclado.
MCP_SESSION_MAX_USES=100

# Límite de tiempo máximo en segundos para esperar a que una herramienta MCP responda antes de lanzar timeout.
MCP_TOOL_CALL_TIMEOUT_SECONDS=300

# Habilita el control de idempotencia para evitar volver a ejecutar herramientas con idénticos parámetros.
TOOL_IDEMPOTENCY_ENABLED=true

# Tiempo de vida útil en segundos del caché de un resultado de herramienta para ser considerado reusable.
TOOL_IDEMPOTENCY_STALE_SECONDS=900

# Si es true, aplica políticas de idempotencia en operaciones que escriban o modifiquen archivos locales.
TOOL_IDEMPOTENCY_LOCAL_WRITES=false

# Lista de binarios/comandos del sistema permitidos para ser ejecutados por las herramientas de terminal de los agentes.
WORKSPACE_ALLOWED_COMMANDS=node,npm,npx,pnpm,yarn,python,python3,pip,pytest,git,uvicorn,playwright,vercel,railway

# Límite de caracteres devueltos al agente de la salida de consola de comandos ejecutados en el workspace.
WORKSPACE_MAX_COMMAND_OUTPUT_CHARS=6000

# Permite ejecutar comandos peligrosos o no incluidos en la lista de comandos seguros (por seguridad, false).
WORKSPACE_ALLOW_UNSAFE_COMMANDS=false

# Modo de política de seguridad predeterminado del orquestador (approval_required o full_access).
TOOL_POLICY_MODE=approval_required

# ------------------------------------------------------------
# 4. CAPA DE VOZ Y SÍNTESIS
# ------------------------------------------------------------
# Habilita la salida y reproducción de voz para las respuestas que dan los agentes.
VOICE_CONVERSATIONS_ENABLED=true

# Activa el servicio Chatterbox (Text-To-Speech) local en el orquestador.
CHATTERBOX_ENABLED=true

# Enlace web remoto al servidor que realiza la inferencia rápida de voz (TTS) con Chatterbox.
CHATTERBOX_REMOTE_URL=https://8ec6-35-185-229-22.ngrok-free.app

# ------------------------------------------------------------
# 5. ACTUALIZACIONES AUTOMÁTICAS (AUTO-UPDATES)
# ------------------------------------------------------------
# URL pública en crudo de GitHub que aloja el manifiesto JSON con metadatos y enlaces de nuevas versiones del setup.
UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/Solvealgoritms22/DevFoundry-Releases/main/updates.json
